{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x || 22.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "build": "node scripts/sync-repo-data.mjs && node scripts/prepare-public-assets.mjs && next build",
    "sync-assets": "node scripts/prepare-public-assets.mjs",
    "start": "next start",
    "lint": "next lint",
    "verify:local": "npm run lint && npm run build",
    "verify:full": "npm ci && npm run lint && npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "next": "^14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
