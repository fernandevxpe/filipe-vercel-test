# Copia para .env.local (nunca commits com segredos).
# Supabase → Project Settings → API
#
# Na Vercel podes usar só estes (sem NEXT_PUBLIC_) — o servidor injeta no browser em runtime:
# SUPABASE_URL=...
# SUPABASE_ANON_KEY=...
#
# Ou os públicos (exigem redeploy após alterar, para o bundle cliente atualizar):
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Não uses service_role no browser.
